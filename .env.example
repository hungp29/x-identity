# x-identity environment variables
# Copy to .env and fill in real values before running locally.

# gRPC server port (default: 50051)
GRPC_PORT=50051

# Database connection — credentials are kept separate from the host/name
# so they can be injected as Kubernetes Secrets without embedding them in a URL.
DB_HOST=localhost
DB_PORT=5432
DB_NAME=xidentity
DB_USER=xidentity
DB_PASSWORD=changeme
DB_SSLMODE=disable
DB_SCHEMA=xdata

# Secret key for signing JWT access tokens (required, min 32 chars recommended)
JWT_SECRET=change-me-to-a-long-random-secret

# Access token lifetime (default: 15m)
ACCESS_TOKEN_TTL=15m

# Refresh token / session lifetime (default: 168h = 7 days)
REFRESH_TOKEN_TTL=168h

# Number of consecutive failed logins before the account is locked (default: 5)
MAX_FAILED_LOGINS=5
